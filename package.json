{
  "name": "builder-scaffold",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.17.0",
  "scripts": {
    "fmt": "prettier --write \"move-contracts/**/*.move\"",
    "fmt:ts": "prettier --write \"ts-scripts/**/*.ts\"",
    "fmt:check": "prettier --check \"move-contracts/**/*.move\" \"ts-scripts/**/*.ts\"",
    "lint": "sh scripts/lint-move.sh",
    "configure-rules": "tsx ts-scripts/smart_gate_extension/configure-rules.ts",
    "authorise-gate": "tsx ts-scripts/smart_gate_extension/authorise-gate.ts",
    "authorise-storage-unit": "tsx ts-scripts/smart_gate_extension/authorise-storage-unit.ts",
    "issue-tribe-jump-permit": "tsx ts-scripts/smart_gate_extension/issue-tribe-jump-permit.ts",
    "jump-with-permit": "tsx ts-scripts/smart_gate_extension/jump-with-permit.ts",
    "collect-corpse-bounty": "tsx ts-scripts/smart_gate_extension/collect-corpse-bounty.ts",
    "setup-world-with-version": "bash scripts/setup-world-with-version.sh",
    "publish-tokens": "tsx ts-scripts/tokens/publish-tokens.ts",
    "configure-tribe-token": "tsx ts-scripts/tokens/configure-tribe-token.ts",
    "mint-currency-token": "tsx ts-scripts/tokens/mint-currency-token.ts",
    "mint-tribe-token": "tsx ts-scripts/tokens/mint-tribe-token.ts",
    "transfer-tribe-token": "tsx ts-scripts/tokens/transfer-tribe-token.ts",
    "publish-storage-unit-extension": "tsx ts-scripts/storage_unit_extension/publish-storage-unit-extension.ts",
    "create-marketplace": "tsx ts-scripts/storage_unit_extension/create-marketplace.ts",
    "list-item": "tsx ts-scripts/storage_unit_extension/list-item.ts",
    "buy-item": "tsx ts-scripts/storage_unit_extension/buy-item.ts",
    "create-supply-unit": "tsx ts-scripts/storage_unit_extension/create-supply-unit.ts",
    "stock-supply-unit": "tsx ts-scripts/storage_unit_extension/stock-supply-unit.ts",
    "order-items": "tsx ts-scripts/storage_unit_extension/order-items.ts"
  },
  "dependencies": {
    "@mysten/sui": "^2.0.0",
    "@noble/hashes": "^1.8.0",
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "@mysten/prettier-plugin-move": "^0.3.5",
    "@types/node": "^24.10.4",
    "prettier": "^3.3.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
