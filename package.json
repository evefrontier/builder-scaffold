{
  "name": "builder-scaffold",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.17.0",
  "scripts": {
    "fmt": "prettier --write \"move-contracts/**/*.move\"",
    "fmt:ts": "prettier --write \"ts-scripts/**/*.ts\"",
    "fmt:check": "prettier --check \"move-contracts/**/*.move\" \"ts-scripts/**/*.ts\"",
    "lint": "sh scripts/lint-move.sh",
    "setup-world": "bash scripts/setup-world.sh",
    "clean-world": "bash scripts/clean-world-artifacts.sh",
    "rebuild-world": "pnpm clean-world && pnpm setup-world",
    "seed": "tsx ts-scripts/seed.ts",
    "publish-smart-gate-extension": "tsx ts-scripts/smart_gate_extension/publish-smart-gate-extension.ts",
    "configure-rules": "tsx ts-scripts/smart_gate_extension/configure-rules.ts",
    "authorise-gate": "tsx ts-scripts/smart_gate_extension/authorise-gate.ts",
    "issue-tribe-jump-permit": "tsx ts-scripts/smart_gate_extension/issue-tribe-jump-permit.ts",
    "jump-with-permit": "tsx ts-scripts/smart_gate_extension/jump-with-permit.ts",
    "collect-corpse-bounty": "tsx ts-scripts/smart_gate_extension/collect-corpse-bounty.ts",
    "publish-currency-token": "tsx ts-scripts/currency_token/publish.ts",
    "mint-currency-token": "tsx ts-scripts/currency_token/mint.ts",
    "transfer-currency-token": "tsx ts-scripts/currency_token/transfer.ts",
    "publish-tribe-token": "tsx ts-scripts/tribe_token/publish.ts",
    "configure-tribe-token": "tsx ts-scripts/tribe_token/configure.ts",
    "mint-tribe-token": "tsx ts-scripts/tribe_token/mint.ts",
    "transfer-tribe-token": "tsx ts-scripts/tribe_token/transfer.ts"
  },
  "dependencies": {
    "@mysten/sui": "^2.0.0",
    "@noble/hashes": "^1.8.0",
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "@mysten/prettier-plugin-move": "^0.3.5",
    "@types/node": "^24.10.4",
    "prettier": "^3.3.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}