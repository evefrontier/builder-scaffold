# ============================================
# WORLD CONTRACTS (optional; for pnpm setup-world)
# ============================================
# Stable release used by default. Override to use another tag, commit SHA, or main.
# WORLD_CONTRACTS_REF=v0.0.14
# WORLD_CONTRACTS_REPO=https://github.com/evefrontier/world-contracts.git
# WORLD_CONTRACTS_DIR=   # default: sibling of builder-scaffold

# ============================================
# SUI NETWORK
# ============================================
SUI_NETWORK=localnet

# Custom RPC URL (optional, defaults based on network)
# SUI_RPC_URL=http://127.0.0.1:9000

# ============================================
# KEYS & ADDRESSES
# ============================================
ADMIN_ADDRESS=
SPONSOR_ADDRESS=

ADMIN_PRIVATE_KEY=
PLAYER_A_PRIVATE_KEY=
PLAYER_B_PRIVATE_KEY=

# ============================================
# PACKAGE IDS (populated after deployment)
# ============================================
WORLD_PACKAGE_ID=
BUILDER_PACKAGE_ID=
EXTENSION_CONFIG_ID=

# ============================================
# TENANT
# ============================================
TENANT=dev
