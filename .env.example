# ============================================
# SUI NETWORK
# ============================================
SUI_NETWORK=localnet

# Custom RPC URL (optional, defaults based on network)
# SUI_RPC_URL=http://127.0.0.1:9000

# ============================================
# WORLD CONTRACTS
# ============================================
# OPTIONAL; path to world-contracts clone (default: ../world-contracts)
# WORLD_CONTRACTS_DIR=
# OPTIONAL; branch to checkout (default: main); used by setup-world-with-version script
WORLD_CONTRACTS_BRANCH=
# OPTIONAL; if set, checkout this commit; else use latest on branch; leave empty or commented
# WORLD_CONTRACTS_COMMIT=

# ============================================
# KEYS & ADDRESSES
# ============================================
ADMIN_ADDRESS=
PLAYER_A_ADDRESS=
PLAYER_B_ADDRESS=
PLAYER_C_ADDRESS=

ADMIN_PRIVATE_KEY=
PLAYER_A_PRIVATE_KEY=
PLAYER_B_PRIVATE_KEY=
PLAYER_C_PRIVATE_KEY=

# ============================================
# PACKAGE IDS (populated after deployment)
# ============================================
WORLD_PACKAGE_ID=
GATE_EXTENSION_PACKAGE_ID=
GATE_EXTENSION_CONFIG_ID=

# Storage unit extension (after publish-storage-unit-extension)
STORAGE_UNIT_EXTENSION_PACKAGE_ID=
MARKETPLACE_ID=       # after create-marketplace
SUPPLY_UNIT_ID=       # after create-supply-unit

# Token packages (populated after publish-currency-token / publish-tribe-token)
CURRENCY_TOKEN_PACKAGE_ID=
CURRENCY_TREASURY_CAP_ID=
TRIBE_TOKEN_PACKAGE_ID=
TRIBE_TREASURY_CAP_ID=
TRIBE_TOKEN_POLICY_CAP_ID=
TRIBE_TOKEN_POLICY_ID=

# ============================================
# WORLD-CONTRACTS VERSION (local only; optional)
# ============================================
# Pin which world-contracts version to deploy and build against.
# Used by pnpm setup-world-with-version (scripts/setup-world-with-version.sh)
# WORLD_CONTRACTS_BRANCH=main
# WORLD_CONTRACTS_COMMIT=   # optional; if set, checkout this commit; else use latest on branch; leave empty or commented
# WORLD_CONTRACTS_DIR=      # optional; path to world-contracts clone (default: ../world-contracts)
#                           # Docker: use /workspace/world-contracts when running inside container

# ============================================
# TENANT
# ============================================
TENANT=dev
