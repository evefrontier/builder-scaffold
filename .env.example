# ============================================
# SUI NETWORK
# ============================================
SUI_NETWORK=localnet

# Custom RPC URL (optional, defaults based on network)
# SUI_RPC_URL=http://127.0.0.1:9000

# ============================================
# WORLD CONTRACTS VERSION
# ============================================
# Branch to checkout (default: main); used by pnpm setup-world
WORLD_CONTRACTS_BRANCH=
# Pin to a specific tag or commit SHA (e.g. v0.0.15); overrides branch tip when set
# Check latest stable tags: https://github.com/evefrontier/world-contracts/tags
# WORLD_CONTRACTS_COMMIT=
# Path to world-contracts clone (default: ../world-contracts)
# WORLD_CONTRACTS_DIR=

# ============================================
# KEYS & ADDRESSES  (required)
# ============================================
ADMIN_ADDRESS=
PLAYER_A_ADDRESS=
PLAYER_B_ADDRESS=
PLAYER_C_ADDRESS=

ADMIN_PRIVATE_KEY=
PLAYER_A_PRIVATE_KEY=
PLAYER_B_PRIVATE_KEY=
PLAYER_C_PRIVATE_KEY=

# ============================================
# AUTO-POPULATED IDs  (do not set unless overriding or want to reference here instead of deployment files)
# ============================================
# All IDs below are read automatically from deployment files after running the publish scripts:
#   deployments/<network>/extracted-object-ids.json  — package IDs, treasury caps, extension configs
#
# Set a variable here only if you need to override the file-based value.

# World (from setup-world → extracted-object-ids.json)
# WORLD_PACKAGE_ID=

# Smart gate extension (from pnpm publish-smart-gate-extension → extracted-object-ids.json)
# GATE_EXTENSION_PACKAGE_ID=
# GATE_EXTENSION_CONFIG_ID=

# Currency token (from pnpm publish-currency-token → extracted-object-ids.json)
# CURRENCY_TOKEN_PACKAGE_ID=
# CURRENCY_TREASURY_CAP_ID=

# Tribe token (from pnpm publish-tribe-token → extracted-object-ids.json)
# TRIBE_TOKEN_PACKAGE_ID=
# TRIBE_TREASURY_CAP_ID=
# TRIBE_TOKEN_POLICY_CAP_ID=
# TRIBE_TOKEN_POLICY_ID=

# ============================================
# TENANT
# ============================================
TENANT=dev
